{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Alcove AI Eval Review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "verdict",
    "score",
    "module_scores",
    "findings",
    "strong_points",
    "untested_risks"
  ],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["pass", "needs_fixes"]
    },
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "module_scores": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["module", "score"],
        "properties": {
          "module": {
            "type": "string"
          },
          "score": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "module", "summary", "evidence", "recommendation"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["blocking", "should_fix", "nice_to_have"]
          },
          "module": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "evidence": {
            "type": "string"
          },
          "recommendation": {
            "type": "string"
          }
        }
      }
    },
    "strong_points": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "untested_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
